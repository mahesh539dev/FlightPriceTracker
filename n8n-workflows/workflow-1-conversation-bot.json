    },
    {
      "parameters": {
        "chatId": "={{ $json.chat_id }}",
        "text": "=Current Prices for {{ $json.from_airport }} → {{ $json.to_airport }}:\n━━━━━━━━━━━━━━━━━━━━\n\n{{ $json.price_1 }} - {{ $json.airline_1 }}\nFlight: {{ $json.flights_1 }}\n\n{{ $json.price_2 }} - {{ $json.airline_2 }}\nFlight: {{ $json.flights_2 }}\n\n{{ $json.price_3 }} - {{ $json.airline_3 }}\nFlight: {{ $json.flights_3 }}\n\n━━━━━━━━━━━━━━━━━━━━\nTracking is now ACTIVE!\nI'll check prices hourly and alert you when they drop.\n\nSend /stop to stop tracking\nSend /status for current prices",
        "additionalFields": {}
      },
      "name": "Send Price Results",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [2300, 1750]
    },
